{
    "name": "marko/layout",
    "description": "Marko Framework Layout - Layout system with components and slots",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "marko/core": "self.version",
        "marko/routing": "self.version",
        "marko/view": "self.version"
    },
    "require-dev": {
        "marko/testing": "self.version",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Layout\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Layout\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
